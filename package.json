{
  "name": "likelion-usw-cms-fe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "typecheck": "tsc -b",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "api:fetch": "node scripts/fetch-swagger.mjs",
    "api:types": "openapi-typescript openapi/openapi.json -o src/api/types.generated.ts",
    "api:sync": "npm run api:fetch && npm run api:types"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "openapi-typescript": "^7.13.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9",
    "vite": "^8.1.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
