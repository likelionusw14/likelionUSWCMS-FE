{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases (vite.config.ts 가 vite-tsconfig-paths 로 동일하게 해석) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@atoms": ["src/components/atoms/index.ts"],
      "@atoms/*": ["src/components/atoms/*"],
      "@molecules": ["src/components/molecules/index.ts"],
      "@molecules/*": ["src/components/molecules/*"],
      "@organisms": ["src/components/organisms/index.ts"],
      "@organisms/*": ["src/components/organisms/*"],
      "@templates": ["src/components/templates/index.ts"],
      "@templates/*": ["src/components/templates/*"],
      "@routes": ["src/routes/index.ts"],
      "@routes/*": ["src/routes/*"],
      "@api": ["src/api/index.ts"],
      "@api/*": ["src/api/*"],
      "@hooks": ["src/hooks/index.ts"],
      "@hooks/*": ["src/hooks/*"],
      "@store": ["src/store/index.ts"],
      "@store/*": ["src/store/*"],
      "@types": ["src/types/index.ts"],
      "@types/*": ["src/types/*"],
      "@constants": ["src/constants/index.ts"],
      "@constants/*": ["src/constants/*"],
      "@utils": ["src/utils/index.ts"],
      "@utils/*": ["src/utils/*"],
      "@config": ["src/config/index.ts"],
      "@config/*": ["src/config/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
